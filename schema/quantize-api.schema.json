          "type": "string"
        },
        "version": {
          "type": "integer"
        }
      },
      "required": [
        "strategy_id",
        "version",
        "name",
        "schema_version",
        "saved_at"
      ],
      "title": "StrategyListRow",
      "type": "object"
    },
    "StrategySaved": {
      "additionalProperties": false,
      "description": "Acknowledgement of a persisted strategy version.",
      "properties": {
        "strategy_id": {
          "type": "string"
        },
        "version": {
          "type": "integer"
        }
      },
      "required": [
        "strategy_id",
        "version"
      ],
      "title": "StrategySaved",
      "type": "object"
    },
    "StructuralDiagnosticDto": {
      "additionalProperties": false,
      "description": "One structural (M1.2) fault: located by document ``loc`` (e.g. ``(\"edges\", 2, \"from\")``).",
      "properties": {
        "code": {
          "type": "string"
        },
        "loc": {
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              }
            ]
          },
          "type": "array"
        },
        "message": {
          "type": "string"
        },
        "subject": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "code",
        "message",
        "loc"
      ],
      "title": "StructuralDiagnosticDto",
      "type": "object"
    },
    "TimeSeriesType": {
      "additionalProperties": false,
      "properties": {
        "dtype": {
          "const": "Number",
          "type": "string"
        },
        "kind": {
          "const": "TimeSeries",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "dtype"
      ],
      "title": "TimeSeriesType",
      "type": "object"
    },
    "TraceEvent": {
      "additionalProperties": false,
      "description": "One structured decision-trace event (envelope only; ``payload`` shape is per-node).",
      "properties": {
        "component_path": {
          "default": [],
          "items": {
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_]+$",
            "type": "string"
          },
          "type": "array"
        },
        "event_type": {
          "minLength": 1,
          "type": "string"
        },
        "node_id": {
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_]+$",
          "type": "string"
        },
        "payload": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        "run_id": {
          "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "timestamp",
        "node_id",
        "event_type",
        "payload"
      ],
      "title": "TraceEvent",
      "type": "object"
    },
    "TraceResponse": {
      "additionalProperties": false,
      "description": "The run's decision-trace events in stored sequence order (optionally session-filtered).",
      "properties": {
        "events": {
          "items": {
            "$ref": "#/$defs/TraceEvent"
          },
          "type": "array"
        }
      },
      "required": [
        "events"
      ],
      "title": "TraceResponse",
      "type": "object"
    },
    "ValidateResponse": {
      "additionalProperties": false,
      "description": "The run-faithful validation verdict. ``ok`` is true only when every layer is clean; on ok\nit additionally reports ``warmup_sessions`` (the resolved warm-up the run would require).",
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "runtime": {
          "items": {
            "$ref": "#/$defs/RuntimeDiagnosticDto"
          },
          "type": "array"
        },
        "semantic": {
          "items": {
            "$ref": "#/$defs/SemanticDiagnosticDto"
          },
          "type": "array"
        },
        "structural": {
          "items": {
            "$ref": "#/$defs/StructuralDiagnosticDto"
          },
          "type": "array"
        },
        "warmup_sessions": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "ok",
        "structural",
        "semantic",
        "runtime"
      ],
      "title": "ValidateResponse",
      "type": "object"
    },
    "VersionList": {
      "additionalProperties": false,
      "description": "The ascending version numbers stored for one strategy id.",
      "properties": {
        "versions": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        }
      },
      "required": [
        "versions"
      ],
      "title": "VersionList",
      "type": "object"
    }
  },
