{
  "name": "quantize-web",
  "private": true,
  "type": "module",
  "description": "Quantize editor (M11) — Vite React-TS app; consumes the generated ../ts types.",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "e2e:viewport": "node e2e/run.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xyflow/react": "12.8.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "25.0.1",
    "typescript": "5.7.3",
    "vite": "6.0.7",
    "vitest": "2.1.8"
  }
}
